APP_NAME=Verdalis Foods
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Comma-separated frontend origins (Vite dev ports + production domains)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175,http://localhost:5176
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5174,localhost:5175,localhost:5176,127.0.0.1,127.0.0.1:8000

SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false

# Main admin account (dev only — disabled in production via AppServiceProvider)
APP_ADMIN_NAME="Admin"
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=changeme

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prime_fine_foods
DB_USERNAME=root
DB_PASSWORD=

# Production: use Redis for cache, queue, and sessions
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Local dev without Redis:
# CACHE_STORE=database
# QUEUE_CONNECTION=database
# SESSION_DRIVER=database

SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5174/dashboard/orders
STRIPE_CANCEL_URL=http://localhost:5174/checkout

VITE_GOOGLE_CLIENT_ID="${GOOGLE_CLIENT_ID}"

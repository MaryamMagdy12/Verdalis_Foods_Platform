# =============================================================================
# Verdalis Foods API — Environment Configuration
# =============================================================================
# Copy to .env and fill in values. Never commit .env to version control.
#
# Local development: MySQL + database cache/queue/session (no Redis required)
# Production (Render + Neon): PostgreSQL + database drivers (Redis optional)
# =============================================================================

APP_NAME="Verdalis Foods"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Public asset base (optional). Defaults to APP_URL. Use when API and storage CDN differ.
# ASSET_URL=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# Frontend URLs (Vercel) — required in production for emails & Stripe redirects
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175
SHIPPER_URL=http://localhost:5176

# Comma-separated origins for CORS (must include all Vercel frontend URLs in prod)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175,http://localhost:5176

# Comma-separated hosts for Sanctum SPA cookie auth (host only, no protocol)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5174,localhost:5175,localhost:5176,127.0.0.1,127.0.0.1:8000

# -----------------------------------------------------------------------------
# Session & cookies
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Production (HTTPS): set to true
SESSION_SECURE_COOKIE=false
# Cross-subdomain SPA (api + frontends on different domains): may need "none"
# SESSION_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Cache & queue (database = free-hosting safe; Redis = optional performance)
# -----------------------------------------------------------------------------
CACHE_STORE=database
QUEUE_CONNECTION=database

# Optional Redis (Render paid add-on or external Redis)
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Database — Local (MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prime_fine_foods
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Database — Production (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# DB_CONNECTION=pgsql
# DB_HOST=your-project.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
# DB_SSLMODE=require
# Or use a single connection URL:
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Dev-only admin bootstrap (disabled when APP_ENV=production)
# -----------------------------------------------------------------------------
APP_ADMIN_NAME="Admin"
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=changeme

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Optional S3 for multi-instance file storage
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Mail (required in production for OTP, orders, password reset)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Google Sign-In (Client frontend)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID="${GOOGLE_CLIENT_ID}"

# -----------------------------------------------------------------------------
# Stripe (online checkout)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5174/dashboard/orders
STRIPE_CANCEL_URL=http://localhost:5174/checkout

# -----------------------------------------------------------------------------
# Geocoding (shipper route map)
# -----------------------------------------------------------------------------
NOMINATIM_USER_AGENT="VerdalisFoodsSiteCatalog/1.0"

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# PRODUCTION CHECKLIST (APP_ENV=production)
# =============================================================================
# APP_DEBUG=false
# APP_KEY=base64:... (php artisan key:generate)
# APP_URL=https://your-api.onrender.com
# FRONTEND_URL, ADMIN_URL, SHIPPER_URL = Vercel URLs
# CORS_ALLOWED_ORIGINS & SANCTUM_STATEFUL_DOMAINS = production domains
# SESSION_SECURE_COOKIE=true
# DB_CONNECTION=pgsql + Neon credentials
# MAIL_* configured
# GOOGLE_CLIENT_ID set
# STRIPE_* set including STRIPE_WEBHOOK_SECRET
# Remove or leave blank: APP_ADMIN_PASSWORD (auto-seed disabled in production)
